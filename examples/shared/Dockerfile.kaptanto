FROM golang:1.25 AS build

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY cmd ./cmd
COPY internal ./internal

RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/kaptanto ./cmd/kaptanto

FROM debian:bookworm-slim

COPY --from=build /out/kaptanto /usr/local/bin/kaptanto

ENTRYPOINT ["kaptanto"]

